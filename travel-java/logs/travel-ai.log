2026-06-25 15:26:20.066 [http-nio-3200-exec-1] DEBUG c.whoa.mapper.FavoriteMapper.insert - ==> Parameters: 2(Long), itinerary(String), 大理 3日行程(String), {"budgetBreakdown":{"accommodation":6000,"food":5000,"other":4000,"tickets":1000,"transportation":4000},"city":"大理","dailyItinerary":[{"afternoon":{"description":"大理古城始建于明洪武十五年，承载着大理千年历史文化。城内呈棋盘式格局，青瓦白墙的白族民居错落有致。可漫步人民路、洋人街，游览五华楼、大理古城文庙，感受文艺气息与南诏古国底蕴的交融。","duration":"3小时","spot":"大理古城","ticket":"免费","transportation":"从苍山索道下站步行或乘坐电瓶车前往"},"date":"第1天","day":1,"evening":{"description":"大理的夜晚属于民谣与美食。在古城内品尝正宗的白族酸辣鱼或野生菌火锅后，钻进一家氛围感十足的民谣酒馆，点一杯特调鸡尾酒，听驻唱歌手吟唱诗与远方，体验大理独有的慢生活夜文化。","duration":"3小时","spot":"古城民谣酒馆与特色晚餐","ticket":"人均150元","transportation":"步行"},"morning":{"description":"苍山是云岭山脉南端的主峰，由十九座山峰和十八条溪流组成。乘坐洗马潭大索道可直达海拔3900米的山顶，沿途可俯瞰洱海全景，欣赏高山杜鹃和冷杉林，感受'苍山雪'的壮丽与苍山的冰川遗迹。","duration":"4小时","spot":"苍山风景区（洗马潭大索道）","ticket":"300元","transportation":"打车或专车直达索道下站"}},{"afternoon":{"description":"环海东路被誉为大理最美环海公路，一面是陡峭的青山，一面是广阔的洱海，风景极其壮美。途中停靠小普陀，这是洱海中的一座袖珍小岛，形如一枚印章，冬季常有红嘴鸥在此栖息，可乘船登岛感受佛教文化。","duration":"3小时","spot":"环海东路与小普陀","ticket":"小普陀游船5元","transportation":"包车或自驾沿环海东路行驶"},"date":"第2天","day":2,"evening":{"description":"在洱海边的轻奢海景餐厅享用精致晚餐，伴着落日余晖品尝美食。夜幕降临后，若无光污染，可在露台仰望苍洱之间的璀璨星空，享受极致浪漫的静谧时光。","duration":"2.5小时","spot":"洱海星空海景餐厅","ticket":"人均400元","transportation":"专车返回酒店或前往海东餐厅"},"morning":{"description":"双廊被誉为'苍洱风光第一镇'，位于洱海东北岸。这里门迎碧波洱海，远眺苍山十九峰。古镇内有许多文艺的客栈和咖啡馆，还可参观著名舞蹈家杨丽萍的太阳宫和月亮宫，是感受大理'风花雪月'绝佳的观景地。","duration":"3小时","spot":"双廊古镇","ticket":"免费","transportation":"包车或自驾前往"}},{"afternoon":{"description":"洱海生态廊道是近年来大理的网红打卡地，全程禁机动车，只能步行或骑行。租一辆自行车迎着微风骑行，近距离接触洱海。随后前往海舌公园，这是一块三面环水的长形沙洲，犹如舌头伸入洱海，古木参天，极其幽静。","duration":"3小时","spot":"洱海生态廊道与海舌公园","ticket":"免费（生态廊道骑行租车约50元）","transportation":"骑行或乘坐生态廊道观光车"},"date":"第3天","day":3,"evening":{"description":"行程最后，在古城或下关市区购买大理特色伴手礼，如沱茶、鲜花饼、扎染工艺品或雕梅。随后根据航班或高铁时间，前往大理机场或大理站，结束愉快的大理之旅。","duration":"2小时","spot":"伴手礼采购与返程","ticket":"无","transportation":"打车前往机场或高铁站"},"morning":{"description":"喜洲是白族文化的重要发祥地之一，保存着最多、最好的白族民居建筑群，以'三坊一照壁'、'四合五天井'为特色。走在青石板路上，品尝刚出炉的喜洲粑粑，体验白族扎染工艺，感受浓郁的烟火气与非遗魅力。","duration":"2.5小时","spot":"喜洲古镇","ticket":"免费","transportation":"包车或打车前往"}}],"days":3,"error":null,"rawResponse":null,"success":true,"tips":["大理紫外线极强，无论阴晴，请务必做好防晒措施（墨镜、防晒霜、遮阳帽）。","早晚温差较大，即使夏季也建议携带一件防风保暖的外套。","2万元预算充裕，建议全程包车或租赁敞篷跑车环海，体验感极佳且节省体力。","品尝野生菌火锅时，请务必在正规餐厅食用，并确保菌类完全煮熟。"],"totalBudget":20000,"warnings":["洱海周边部分区域为生态保护红线区，严禁驾车进入滩涂或下水，请遵守生态保护规定。","苍山洗马潭索道海拔较高，有轻微高反风险，请勿剧烈运动，心脏病及高血压患者请量力而行。","环海东路部分路段弯多坡陡，若自驾请谨慎驾驶，切勿边开车边看风景或随意路边违停拍照。"]}(String)
