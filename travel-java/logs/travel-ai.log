2026-06-25 14:58:26.369 [http-nio-3200-exec-2] DEBUG c.whoa.mapper.FavoriteMapper.insert - ==> Parameters: 2(Long), itinerary(String), 北京 3日行程(String), {"budgetBreakdown":{"accommodation":1500,"food":1200,"other":1500,"tickets":300,"transportation":500},"city":"北京","dailyItinerary":[{"afternoon":{"description":"景山公园位于故宫北侧，登上万春亭可以俯瞰整个故宫的全貌，金瓦红墙连绵不绝，是拍摄故宫全景的最佳机位，也是了解北京中轴线历史的绝佳地点。","duration":"1.5小时","spot":"景山公园","ticket":"2元","transportation":"从故宫神武门步行即可到达"},"date":"第1天","day":1,"evening":{"description":"北京最著名的商业街之一，集购物、餐饮、娱乐于一体。可以品尝东来顺的涮肉、全聚德的烤鸭，或在小吃街体验各类特色小吃，感受京城繁华的夜生活。","duration":"2小时","spot":"王府井步行街","ticket":"0元","transportation":"地铁1号线王府井站"},"morning":{"description":"故宫又称紫禁城，是明清两代的皇家宫殿，也是世界上现存规模最大、保存最为完整的木质结构古建筑之一。漫步其中，可以感受厚重的历史底蕴与皇家威严，推荐游览中轴线及珍宝馆、钟表馆。","duration":"4小时","spot":"故宫博物院","ticket":"60元","transportation":"地铁1号线天安门东站"}},{"afternoon":{"description":"2008年北京奥运会的核心场馆。鸟巢宏伟震撼，水立方灵动现代，夜晚亮灯后更是绝美，是感受双奥之城魅力的绝佳去处，周边广场适合散步拍照。","duration":"2.5小时","spot":"奥林匹克公园（鸟巢、水立方）","ticket":"0元（外观免费，入内需另购票）","transportation":"地铁8号线奥林匹克公园站"},"date":"第2天","day":2,"evening":{"description":"北京最时尚的潮流街区，汇聚了众多国际品牌、设计师买手店和各国美食。这里的夜生活丰富多彩，是体验北京现代、年轻、国际化一面的首选地。","duration":"2小时","spot":"三里屯太古里","ticket":"0元","transportation":"地铁10号线团结湖站"},"morning":{"description":"不到长城非好汉！八达岭长城是万里长城最具代表性的段落，地势险峻，气势磅礴。建议早出发以避开人流高峰，可选择南段或北段攀登，感受古代军事防御工程的伟大。","duration":"4小时","spot":"八达岭长城","ticket":"40元","transportation":"市郊铁路S2线或877路公交"}},{"afternoon":{"description":"南锣鼓巷是北京最古老的街区之一，充满文艺气息与胡同文化；什刹海包括前海、后海，老北京风情浓郁，沿湖漫步，可参观恭王府，或在胡同里找寻地道的京味小吃。","duration":"3小时","spot":"南锣鼓巷与什刹海","ticket":"0元","transportation":"地铁6号线南锣鼓巷站/8号线什刹海站"},"date":"第3天","day":3,"evening":{"description":"老北京风情街，拥有众多百年老字号店铺。夜晚灯火辉煌，可以在这里享用一顿正宗的北京烤鸭作为告别晚宴，感受古都夜晚的独特韵味。","duration":"2小时","spot":"前门大街","ticket":"0元","transportation":"地铁2号线前门站"},"morning":{"description":"中国现存最大的皇家园林，以昆明湖、万寿山为基址，汲取江南园林的设计手法建成。长廊、十七孔桥、佛香阁等景点美不胜收，是感受皇家休闲生活的绝佳去处。","duration":"3.5小时","spot":"颐和园","ticket":"30元","transportation":"地铁4号线北宫门站"}}],"days":3,"error":null,"rawResponse":null,"success":true,"tips":["北京景点面积大且人流量多，建议穿舒适的平底鞋或运动鞋。","北京市内出行首选地铁，不仅不堵车且覆盖所有核心景区，可下载'亿通行'APP扫码乘车。","去八达岭长城建议乘坐市郊铁路S2线，赏花季风景极佳，需提前关注列车时刻表。"],"totalBudget":5000,"warnings":["故宫博物院实行实名制预约购票，每日限流，务必提前7天在官方小程序上抢票，切勿相信黄牛。","长城脚下有黑导游和非法拉客车辆，请务必乘坐官方公交（877路）或正规市郊铁路前往。","部分景点（如故宫、国家博物馆）周一闭馆，请合理安排行程避开周一。"]}(String)
